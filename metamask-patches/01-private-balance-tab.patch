diff --git a/ui/components/app/assets/private-balance-tab/nox-client.ts b/ui/components/app/assets/private-balance-tab/nox-client.ts
new file mode 100644
index 0000000..0cc68bd
--- /dev/null
+++ b/ui/components/app/assets/private-balance-tab/nox-client.ts
@@ -0,0 +1,211 @@
+// Self-contained Nox Handle Gateway client for the MetaMask Private Balance
+// tab. Re-implements @iexec-nox/handle's `decrypt()` flow using Web Crypto API
+// so nothing needs to be bundled into the extension sandbox.
+//
+// Chain config is hardcoded for Arbitrum Sepolia (chainId 421614).
+
+import { noxSignTypedDataV4 } from '../../../../store/actions';
+
+const HANDLE_GATEWAY =
+  'https://2e1800fc0dddeeadc189283ed1dce13c1ae28d48-3000.apps.ovh-tdx-dev.noxprotocol.dev';
+const NOX_COMPUTE = '0xd464B198f06756a1d00be223634b85E0a731c229';
+const CHAIN_ID = 421614;
+
+const DERIVATION_INFO = new Uint8Array([
+  0x45, 0x43, 0x49, 0x45, 0x53, 0x3a, 0x41, 0x45, 0x53, 0x5f, 0x47, 0x43, 0x4d,
+  0x3a, 0x76, 0x31,
+]); // "ECIES:AES_GCM:v1"
+
+function bytesToHex(bytes: Uint8Array): string {
+  let out = '0x';
+  for (const b of bytes) out += b.toString(16).padStart(2, '0');
+  return out;
+}
+
+function hexToBytes(hex: string): Uint8Array {
+  const clean = hex.replace(/^0x/, '');
+  const out = new Uint8Array(clean.length / 2);
+  for (let i = 0; i < out.length; i++) {
+    out[i] = parseInt(clean.slice(i * 2, i * 2 + 2), 16);
+  }
+  return out;
+}
+
+type DataAccessMessage = {
+  userAddress: string;
+  encryptionPubKey: string;
+  notBefore: number;
+  expiresAt: number;
+};
+
+// Critical: the `message` we sign and the `payload` we send to the gateway
+// MUST be byte-identical (same notBefore/expiresAt). Recomputing `now` twice
+// yields different timestamps → signature verification fails with 401.
+function buildTypedData(userAddress: string, encryptionPubKey: string) {
+  const now = Math.floor(Date.now() / 1000);
+  const message: DataAccessMessage = {
+    userAddress,
+    encryptionPubKey,
+    notBefore: now,
+    expiresAt: now + 3600,
+  };
+  return {
+    types: {
+      EIP712Domain: [
+        { name: 'name', type: 'string' },
+        { name: 'version', type: 'string' },
+        { name: 'chainId', type: 'uint256' },
+        { name: 'verifyingContract', type: 'address' },
+      ],
+      DataAccessAuthorization: [
+        { name: 'userAddress', type: 'address' },
+        { name: 'encryptionPubKey', type: 'string' },
+        { name: 'notBefore', type: 'uint256' },
+        { name: 'expiresAt', type: 'uint256' },
+      ],
+    },
+    domain: {
+      name: 'Handle Gateway',
+      version: '1',
+      chainId: CHAIN_ID,
+      verifyingContract: NOX_COMPUTE,
+    },
+    primaryType: 'DataAccessAuthorization',
+    message,
+  };
+}
+
+function buildAuthorizationHeader(
+  message: DataAccessMessage,
+  signature: string,
+): string {
+  return `EIP712 ${btoa(JSON.stringify({ payload: message, signature }))}`;
+}
+
+async function generateEphemeralKeyPair(): Promise<{
+  publicKeyHex: string;
+  privateKey: CryptoKey;
+}> {
+  const keyPair = (await crypto.subtle.generateKey(
+    {
+      name: 'RSA-OAEP',
+      modulusLength: 2048,
+      publicExponent: new Uint8Array([0x01, 0x00, 0x01]),
+      hash: 'SHA-256',
+    },
+    true,
+    ['decrypt'],
+  )) as CryptoKeyPair;
+  const spki = await crypto.subtle.exportKey('spki', keyPair.publicKey);
+  return {
+    publicKeyHex: bytesToHex(new Uint8Array(spki)),
+    privateKey: keyPair.privateKey,
+  };
+}
+
+async function fetchCipher(
+  handle: string,
+  authHeader: string,
+): Promise<{ ciphertext: Uint8Array; iv: Uint8Array; encryptedSharedSecret: Uint8Array }> {
+  const res = await fetch(`${HANDLE_GATEWAY}/v0/secrets/${handle}`, {
+    headers: { Authorization: authHeader },
+  });
+  if (!res.ok) {
+    const body = await res.text();
+    throw new Error(`Gateway ${res.status}: ${body}`);
+  }
+  // Gateway response shape: { payload: {...}, signature }
+  const json = (await res.json()) as {
+    payload: {
+      handle: string;
+      ciphertext: string;
+      iv: string;
+      encryptedSharedSecret: string;
+    };
+    signature: string;
+  };
+  return {
+    ciphertext: hexToBytes(json.payload.ciphertext),
+    iv: hexToBytes(json.payload.iv),
+    encryptedSharedSecret: hexToBytes(json.payload.encryptedSharedSecret),
+  };
+}
+
+async function eciesDecrypt(
+  encryptedSharedSecret: Uint8Array,
+  iv: Uint8Array,
+  ciphertext: Uint8Array,
+  rsaPrivate: CryptoKey,
+): Promise<Uint8Array> {
+  const sharedSecretBuf = await crypto.subtle.decrypt(
+    { name: 'RSA-OAEP' },
+    rsaPrivate,
+    encryptedSharedSecret,
+  );
+  const keyMaterial = await crypto.subtle.importKey(
+    'raw',
+    new Uint8Array(sharedSecretBuf),
+    'HKDF',
+    false,
+    ['deriveKey'],
+  );
+  const aesKey = await crypto.subtle.deriveKey(
+    {
+      name: 'HKDF',
+      hash: 'SHA-256',
+      salt: new Uint8Array(32),
+      info: DERIVATION_INFO,
+    },
+    keyMaterial,
+    { name: 'AES-GCM', length: 256 },
+    false,
+    ['decrypt'],
+  );
+  const plainBuf = await crypto.subtle.decrypt(
+    { name: 'AES-GCM', iv, tagLength: 128 },
+    aesKey,
+    ciphertext,
+  );
+  return new Uint8Array(plainBuf);
+}
+
+/**
+ * Decode the plaintext bytes returned by the Handle Gateway.
+ *
+ * Nox handle layout (32 bytes):
+ *   byte 0     version
+ *   bytes 1-4  chainId (big-endian uint32)
+ *   byte 5     type code (SOLIDITY_TYPES index — uint256 = 35, uint16 = 5, etc.)
+ *   byte 6     attribute
+ *   bytes 7-31 random/unique
+ *
+ * For ERC-7984 balance/amount handles the type is uintN so we always decode
+ * the plaintext as a big-endian unsigned integer.
+ */
+function decodePlaintext(handleHex: string, plain: Uint8Array): bigint {
+  const bytes = hexToBytes(handleHex);
+  const typeCode = bytes[5];
+  // Accept any uintN (4..35) or intN (36..67)
+  if (typeCode < 4 || typeCode > 67) {
+    throw new Error(`Unsupported handle type code ${typeCode}`);
+  }
+  let value = 0n;
+  for (const b of plain) value = (value << 8n) + BigInt(b);
+  return value;
+}
+
+export async function noxDecrypt(
+  userAddress: string,
+  handle: string,
+): Promise<bigint> {
+  const { publicKeyHex, privateKey } = await generateEphemeralKeyPair();
+  const typedData = buildTypedData(userAddress, publicKeyHex);
+  const signature = await noxSignTypedDataV4(typedData, userAddress);
+  // Reuse the exact same message that was signed, otherwise the gateway
+  // recomputes the EIP-712 digest with different timestamps and rejects.
+  const headerValue = buildAuthorizationHeader(typedData.message, signature);
+
+  const { ciphertext, iv, encryptedSharedSecret } = await fetchCipher(handle, headerValue);
+  const plain = await eciesDecrypt(encryptedSharedSecret, iv, ciphertext, privateKey);
+  return decodePlaintext(handle, plain);
+}
diff --git a/ui/components/app/assets/private-balance-tab/nox-rpc.ts b/ui/components/app/assets/private-balance-tab/nox-rpc.ts
new file mode 100644
index 0000000..d415e86
--- /dev/null
+++ b/ui/components/app/assets/private-balance-tab/nox-rpc.ts
@@ -0,0 +1,344 @@
+const ARB_SEPOLIA_RPC = 'https://sepolia-rollup.arbitrum.io/rpc';
+const ZERO_HANDLE = '0x' + '00'.repeat(32);
+
+const HANDLE_GATEWAY =
+  'https://2e1800fc0dddeeadc189283ed1dce13c1ae28d48-3000.apps.ovh-tdx-dev.noxprotocol.dev';
+
+export const NOX_DAPP_ORIGIN =
+  (globalThis as { VITE_NOX_APP_ORIGIN?: string }).VITE_NOX_APP_ORIGIN ||
+  'http://localhost:5180';
+
+// Selector for confidentialBalanceOf(address) returning bytes32.
+// keccak256("confidentialBalanceOf(address)").slice(0, 4) = 0x344ff101
+const CONFIDENTIAL_BALANCE_OF_SELECTOR = '0x344ff101';
+
+function addrToCallData(address: string): string {
+  const clean = address.toLowerCase().replace(/^0x/, '').padStart(64, '0');
+  return CONFIDENTIAL_BALANCE_OF_SELECTOR + clean;
+}
+
+export async function fetchBalanceHandle(
+  token: string,
+  owner: string,
+): Promise<{ handle: string; zero: boolean }> {
+  const body = {
+    jsonrpc: '2.0',
+    id: 1,
+    method: 'eth_call',
+    params: [
+      { to: token, data: addrToCallData(owner) },
+      'latest',
+    ],
+  };
+
+  const res = await fetch(ARB_SEPOLIA_RPC, {
+    method: 'POST',
+    headers: { 'content-type': 'application/json' },
+    body: JSON.stringify(body),
+  });
+  if (!res.ok) throw new Error(`RPC ${res.status}: ${await res.text()}`);
+
+  const json = (await res.json()) as { result?: string; error?: { message: string } };
+  if (json.error) throw new Error(`RPC error: ${json.error.message}`);
+  if (!json.result || json.result.length !== 66) {
+    throw new Error(`Unexpected RPC result: ${JSON.stringify(json)}`);
+  }
+  return {
+    handle: json.result,
+    zero: json.result === ZERO_HANDLE,
+  };
+}
+
+type DeepLinkAction = 'decrypt' | 'send' | 'shield';
+
+export function buildDappDeepLink(
+  action: DeepLinkAction,
+  params: { token?: string; handle?: string } = {},
+): string {
+  const base = `${NOX_DAPP_ORIGIN}/`;
+  const q = new URLSearchParams();
+  q.set('view', action);
+  if (params.token) q.set('token', params.token);
+  if (params.handle) q.set('handle', params.handle);
+  return `${base}?${q.toString()}`;
+}
+
+/** POST /v0/secrets — encrypts an input via the Handle Gateway. No EIP-712
+ *  auth needed (ACL is enforced later on-chain via the inputProof). */
+export async function encryptUint256(
+  applicationContract: string,
+  owner: string,
+  amount: bigint,
+): Promise<{ handle: `0x${string}`; proof: `0x${string}` }> {
+  // Gateway expects the value encoded as 32-byte big-endian hex for uint256
+  const valueHex = '0x' + amount.toString(16).padStart(64, '0');
+  const res = await fetch(`${HANDLE_GATEWAY}/v0/secrets`, {
+    method: 'POST',
+    headers: { 'content-type': 'application/json' },
+    body: JSON.stringify({
+      value: valueHex,
+      solidityType: 'uint256',
+      applicationContract,
+      owner,
+    }),
+  });
+  if (!res.ok) {
+    throw new Error(`Gateway ${res.status}: ${await res.text()}`);
+  }
+  // Gateway returns { payload: { handle, proof }, signature }
+  const json = (await res.json()) as {
+    payload: { handle: string; proof: string };
+    signature: string;
+  };
+  return {
+    handle: json.payload.handle as `0x${string}`,
+    proof: json.payload.proof as `0x${string}`,
+  };
+}
+
+// ---- Calldata encoders (manual, no viem import to keep bundle small) -------
+
+function padAddress(addr: string): string {
+  return addr.toLowerCase().replace(/^0x/, '').padStart(64, '0');
+}
+function padUint(v: bigint): string {
+  return v.toString(16).padStart(64, '0');
+}
+function stripHex(h: string): string {
+  return h.replace(/^0x/, '');
+}
+
+export function encodeApprove(spender: string, amount: bigint): `0x${string}` {
+  // approve(address,uint256) selector
+  return ('0x095ea7b3' + padAddress(spender) + padUint(amount)) as `0x${string}`;
+}
+
+export function encodeWrap(to: string, amount: bigint): `0x${string}` {
+  // wrap(address,uint256) selector
+  return ('0xbf376c7a' + padAddress(to) + padUint(amount)) as `0x${string}`;
+}
+
+function encodeDynamicBytes(data: string): string {
+  const hex = stripHex(data);
+  const length = padUint(BigInt(hex.length / 2));
+  const padCount = (64 - (hex.length % 64)) % 64;
+  return length + hex + '0'.repeat(padCount);
+}
+
+export function encodeConfidentialTransfer(
+  to: string,
+  handle: string,
+  inputProof: string,
+): `0x${string}` {
+  return (
+    '0x2fb74e62' +
+    padAddress(to) +
+    stripHex(handle) +
+    padUint(0x60n) +
+    encodeDynamicBytes(inputProof)
+  ) as `0x${string}`;
+}
+
+export function encodeUnwrap(
+  from: string,
+  to: string,
+  encryptedAmount: string,
+  inputProof: string,
+): `0x${string}` {
+  // unwrap(address,address,bytes32,bytes)  selector 0x5bf4ef06
+  // Head: from(32) + to(32) + handle(32) + offset-to-bytes(32 = 0x80)
+  // Tail: length(32) + data_padded
+  return (
+    '0x5bf4ef06' +
+    padAddress(from) +
+    padAddress(to) +
+    stripHex(encryptedAmount) +
+    padUint(0x80n) +
+    encodeDynamicBytes(inputProof)
+  ) as `0x${string}`;
+}
+
+export function encodeFinalizeUnwrap(
+  unwrapRequestId: string,
+  decryptedAmountAndProof: string,
+): `0x${string}` {
+  // finalizeUnwrap(bytes32,bytes)  selector 0x65f94fdb
+  return (
+    '0x65f94fdb' +
+    stripHex(unwrapRequestId) +
+    padUint(0x40n) +
+    encodeDynamicBytes(decryptedAmountAndProof)
+  ) as `0x${string}`;
+}
+
+export function encodeAddViewer(handle: string, viewer: string): `0x${string}` {
+  // addViewer(bytes32,address)  selector 0x10ff39ca
+  return ('0x10ff39ca' + stripHex(handle) + padAddress(viewer)) as `0x${string}`;
+}
+
+// ---- Public decrypt polling (for unwrap finalize proof) --------------------
+
+const UNWRAP_REQUESTED_TOPIC =
+  '0x77d02d353c5629272875d11f1b34ec4c65d7430b075575b78cd2502034c469ee';
+
+/**
+ * Parses a tx receipt's logs and returns the unwrapRequestId emitted by
+ * UnwrapRequested(address indexed to, bytes32 unwrapRequestId). The second
+ * field is non-indexed, so it lives in `data` (no topics beyond the
+ * indexed `to` address).
+ */
+export function parseUnwrapRequestIdFromLogs(
+  logs: readonly { address: string; topics: readonly string[]; data: string }[],
+  wrapperAddress: string,
+): `0x${string}` | null {
+  for (const l of logs) {
+    if (l.address.toLowerCase() !== wrapperAddress.toLowerCase()) continue;
+    if (l.topics[0]?.toLowerCase() !== UNWRAP_REQUESTED_TOPIC) continue;
+    // Non-indexed bytes32 is the first 32 bytes of data
+    const data = l.data.replace(/^0x/, '');
+    if (data.length < 64) continue;
+    return ('0x' + data.slice(0, 64)) as `0x${string}`;
+  }
+  return null;
+}
+
+const CONFIDENTIAL_TRANSFER_TOPIC =
+  '0x67500e8d0ed826d2194f514dd0d8124f35648ab6e3fb5e6ed867134cffe661e9';
+
+export type TransferEvent = {
+  token: `0x${string}`;
+  from: `0x${string}`;
+  to: `0x${string}`;
+  amountHandle: `0x${string}`;
+  txHash: `0x${string}`;
+  blockNumber: number;
+  direction: 'in' | 'out';
+};
+
+function addrTopic(addr: string): string {
+  return '0x' + addr.toLowerCase().replace(/^0x/, '').padStart(64, '0');
+}
+
+/**
+ * Fetch ConfidentialTransfer events involving `user` on the given token
+ * contracts in the last `lookbackBlocks` blocks. Merges "sent" and
+ * "received" into a single chronologically-sorted list.
+ */
+export async function fetchRecentTransfers(
+  user: string,
+  tokens: readonly string[],
+  // Arbitrum Sepolia produces a block every ~250ms, so 2M blocks ≈ 6 days.
+  { lookbackBlocks = 2_000_000, head = 30 }: { lookbackBlocks?: number; head?: number } = {},
+): Promise<TransferEvent[]> {
+  // Get latest block
+  const headRes = await fetch(ARB_SEPOLIA_RPC, {
+    method: 'POST',
+    headers: { 'content-type': 'application/json' },
+    body: JSON.stringify({ jsonrpc: '2.0', id: 1, method: 'eth_blockNumber', params: [] }),
+  });
+  const { result: latestHex } = (await headRes.json()) as { result: string };
+  const latest = parseInt(latestHex, 16);
+  const fromBlock = '0x' + Math.max(0, latest - lookbackBlocks).toString(16);
+  const toBlock = '0x' + latest.toString(16);
+  const userTopic = addrTopic(user);
+
+  async function getLogs(topics: (string | null | string[])[]): Promise<TransferEvent[]> {
+    const res = await fetch(ARB_SEPOLIA_RPC, {
+      method: 'POST',
+      headers: { 'content-type': 'application/json' },
+      body: JSON.stringify({
+        jsonrpc: '2.0', id: 1, method: 'eth_getLogs',
+        params: [{
+          address: tokens as string[],
+          topics, fromBlock, toBlock,
+        }],
+      }),
+    });
+    const json = (await res.json()) as {
+      result?: {
+        address: string; topics: string[]; data: string;
+        transactionHash: string; blockNumber: string;
+      }[];
+      error?: { message: string };
+    };
+    if (json.error) throw new Error(json.error.message);
+    return (json.result ?? []).map((l) => ({
+      token: l.address as `0x${string}`,
+      from: ('0x' + l.topics[1].slice(26)) as `0x${string}`,
+      to: ('0x' + l.topics[2].slice(26)) as `0x${string}`,
+      // Per ERC-7984: event ConfidentialTransfer(address indexed from,
+      // address indexed to, euint256 indexed amount) — amount is an indexed
+      // bytes32 (topics[3]), not in data.
+      amountHandle: (l.topics[3] ?? '0x' + '0'.repeat(64)) as `0x${string}`,
+      txHash: l.transactionHash as `0x${string}`,
+      blockNumber: parseInt(l.blockNumber, 16),
+      direction: 'in', // filled by caller
+    }));
+  }
+
+  const [outLogs, inLogs] = await Promise.all([
+    getLogs([CONFIDENTIAL_TRANSFER_TOPIC, userTopic, null]).then((ls) =>
+      ls.map((l) => ({ ...l, direction: 'out' as const })),
+    ),
+    getLogs([CONFIDENTIAL_TRANSFER_TOPIC, null, userTopic]).then((ls) =>
+      ls.map((l) => ({ ...l, direction: 'in' as const })),
+    ),
+  ]);
+
+  const all = [...outLogs, ...inLogs];
+  // Dedupe (same tx can appear twice if user sends to self)
+  const byKey = new Map<string, TransferEvent>();
+  for (const e of all) {
+    byKey.set(`${e.txHash}:${e.direction}`, e);
+  }
+  return Array.from(byKey.values())
+    .sort((a, b) => b.blockNumber - a.blockNumber)
+    .slice(0, head);
+}
+
+/**
+ * Poll the Handle Gateway for publicDecrypt of a handle that has just been
+ * marked publicly decryptable on-chain (e.g. the burn handle from unwrap).
+ * Returns the signed decryption proof (signature || ABI-encoded plaintext)
+ * that finalizeUnwrap can verify on-chain.
+ */
+export async function publicDecryptProof(
+  handle: string,
+  { attempts = 10, initialDelayMs = 3000 } = {},
+): Promise<{ decryptionProof: `0x${string}`; plaintext: bigint }> {
+  let lastErr: unknown;
+  for (let i = 0; i < attempts; i++) {
+    try {
+      const res = await fetch(`${HANDLE_GATEWAY}/v0/public/${handle}`);
+      if (res.status === 404) {
+        throw new Error('Object not found');
+      }
+      if (!res.ok) {
+        throw new Error(`Gateway ${res.status}: ${await res.text()}`);
+      }
+      const json = (await res.json()) as
+        | { decryptionProof: string }
+        | { payload: { decryptionProof: string }; signature: string };
+      const decryptionProof =
+        ('decryptionProof' in json
+          ? json.decryptionProof
+          : json.payload.decryptionProof) as `0x${string}`;
+      // Proof layout: 65-byte sig + ABI-encoded value.
+      // For uint256 that's 32 bytes → read directly.
+      const hex = decryptionProof.replace(/^0x/, '');
+      const plaintextHex = hex.slice(65 * 2);
+      let plaintext = 0n;
+      for (let j = 0; j < plaintextHex.length; j += 2) {
+        plaintext = (plaintext << 8n) + BigInt(parseInt(plaintextHex.slice(j, j + 2), 16));
+      }
+      return { decryptionProof, plaintext };
+    } catch (err) {
+      lastErr = err;
+      const msg = (err as Error).message ?? '';
+      const isLag = msg.includes('Object not found') || msg.includes('404');
+      if (!isLag) throw err;
+      await new Promise((r) => setTimeout(r, initialDelayMs * (i + 1)));
+    }
+  }
+  throw lastErr;
+}
