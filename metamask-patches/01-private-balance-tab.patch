+// "Decrypt in progress" marker. Written before noxDecrypt() so that if the
+// side panel is destroyed while the user is signing, the freshly-mounted
+// panel can show a spinner (instead of jumping back to "hidden") until the
+// dying panel's saveCachedValue lands.
+const intentKey = (key: string) => `${key}:pending`;
+const PENDING_TTL_MS = 30_000;
+
+async function markPendingDecrypt(key: string): Promise<void> {
+  const storage = getSessionStorage();
+  if (!storage) return;
+  try { await storage.set({ [intentKey(key)]: Date.now() }); } catch { /* noop */ }
+}
+
+async function clearPendingDecrypt(key: string): Promise<void> {
+  const storage = getSessionStorage();
+  if (!storage) return;
+  // chrome.storage.session.remove isn't in our minimal type; cast through.
+  const removable = (storage as unknown as { remove?: (k: string) => Promise<void> }).remove;
+  if (removable) {
+    try { await removable.call(storage, intentKey(key)); } catch { /* noop */ }
+  }
+}
+
+async function isDecryptPending(key: string): Promise<boolean> {
+  const storage = getSessionStorage();
+  if (!storage) return false;
+  try {
+    const out = await storage.get(intentKey(key));
+    const ts = out[intentKey(key)];
+    return typeof ts === 'number' && Date.now() - ts < PENDING_TTL_MS;
+  } catch { return false; }
+}
+
+// NOX_CTOKENS now lives in ./nox-tokens.ts so that the asset details page
+// (which decides when to render the Shield button) shares the same registry.
 
