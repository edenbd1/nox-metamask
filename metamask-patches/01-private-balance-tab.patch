+/**
+ * Nox — sign an EIP-712 typed-data payload from within the MetaMask UI,
+ * used by the Private Balance tab to authenticate decrypt requests to
+ * the Nox Handle Gateway without deep-linking to an external dApp.
+ */
+export async function noxSignTypedDataV4(
+  typedData: unknown,
+  from: string,
+): Promise<string> {
+  log.debug('background.noxSignTypedDataV4');
+  return await submitRequestToBackground<string>('noxSignTypedDataV4', [
+    typedData,
+    from,
+  ]);
+}
