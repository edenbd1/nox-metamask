+/** POST /v0/secrets — encrypts an input via the Handle Gateway. No EIP-712
+ *  auth needed (ACL is enforced later on-chain via the inputProof). */
+export async function encryptUint256(
+  applicationContract: string,
+  owner: string,
+  amount: bigint,
+): Promise<{ handle: `0x${string}`; proof: `0x${string}` }> {
+  // Gateway expects the value encoded as 32-byte big-endian hex for uint256
+  const valueHex = '0x' + amount.toString(16).padStart(64, '0');
+  const res = await fetch(`${HANDLE_GATEWAY}/v0/secrets`, {
+    method: 'POST',
+    headers: { 'content-type': 'application/json' },
+    body: JSON.stringify({
+      value: valueHex,
+      solidityType: 'uint256',
+      applicationContract,
+      owner,
+    }),
+  });
+  if (!res.ok) {
+    throw new Error(`Gateway ${res.status}: ${await res.text()}`);
+  }
+  const json = (await res.json()) as { handle: string; proof: string };
+  return {
+    handle: json.handle as `0x${string}`,
+    proof: json.proof as `0x${string}`,
+  };
+}
+
+// ---- Calldata encoders (manual, no viem import to keep bundle small) -------
+
+function padAddress(addr: string): string {
+  return addr.toLowerCase().replace(/^0x/, '').padStart(64, '0');
+}
+function padUint(v: bigint): string {
+  return v.toString(16).padStart(64, '0');
+}
+function stripHex(h: string): string {
+  return h.replace(/^0x/, '');
+}
+
+export function encodeApprove(spender: string, amount: bigint): `0x${string}` {
+  // approve(address,uint256) selector
+  return ('0x095ea7b3' + padAddress(spender) + padUint(amount)) as `0x${string}`;
+}
+
+export function encodeWrap(to: string, amount: bigint): `0x${string}` {
+  // wrap(address,uint256) selector
+  return ('0xbf376c7a' + padAddress(to) + padUint(amount)) as `0x${string}`;
+}
+
+export function encodeConfidentialTransfer(
+  to: string,
+  handle: string,
+  inputProof: string,
+): `0x${string}` {
+  // confidentialTransfer(address,bytes32,bytes) selector
+  // Head: to (32) + handle (32) + offset-to-bytes (32 = 0x60)
+  // Tail: length(32) + data padded to 32-byte boundary
+  const proofHex = stripHex(inputProof);
+  const proofBytes = proofHex.length / 2;
+  const lengthHex = padUint(BigInt(proofBytes));
+  // pad proof data to next 32-byte boundary
+  const padCount = (64 - (proofHex.length % 64)) % 64;
+  const paddedProof = proofHex + '0'.repeat(padCount);
+  return (
+    '0x2fb74e62' +
+    padAddress(to) +
+    stripHex(handle) +
+    padUint(0x60n) +
+    lengthHex +
+    paddedProof
+  ) as `0x${string}`;
+}
