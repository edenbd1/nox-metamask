+async function loadCachedValue(key: string): Promise<bigint | undefined> {
+  if (hotCache.has(key)) return hotCache.get(key);
+  const storage = getSessionStorage();
+  if (!storage) return undefined;
+  try {
+    const out = await storage.get(key);
+    const raw = out[key];
+    if (typeof raw === 'string') {
+      const v = BigInt(raw);
+      hotCache.set(key, v);
+      return v;
+    }
+  } catch { /* noop */ }
+  return undefined;
+}
