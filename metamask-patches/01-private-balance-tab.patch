+}
+
+// ---- Public decrypt polling (for unwrap finalize proof) --------------------
+
+const UNWRAP_REQUESTED_TOPIC =
+  '0x77d02d353c5629272875d11f1b34ec4c65d7430b075575b78cd2502034c469ee';
+
+/**
+ * Parses a tx receipt's logs and returns the unwrapRequestId emitted by
+ * UnwrapRequested(address indexed to, bytes32 unwrapRequestId). The second
+ * field is non-indexed, so it lives in `data` (no topics beyond the
+ * indexed `to` address).
+ */
+export function parseUnwrapRequestIdFromLogs(
+  logs: readonly { address: string; topics: readonly string[]; data: string }[],
+  wrapperAddress: string,
+): `0x${string}` | null {
+  for (const l of logs) {
+    if (l.address.toLowerCase() !== wrapperAddress.toLowerCase()) continue;
+    if (l.topics[0]?.toLowerCase() !== UNWRAP_REQUESTED_TOPIC) continue;
+    // Non-indexed bytes32 is the first 32 bytes of data
+    const data = l.data.replace(/^0x/, '');
+    if (data.length < 64) continue;
+    return ('0x' + data.slice(0, 64)) as `0x${string}`;
+  }
+  return null;
+}
+
+/**
+ * Poll the Handle Gateway for publicDecrypt of a handle that has just been
+ * marked publicly decryptable on-chain (e.g. the burn handle from unwrap).
+ * Returns the signed decryption proof (signature || ABI-encoded plaintext)
+ * that finalizeUnwrap can verify on-chain.
+ */
+export async function publicDecryptProof(
+  handle: string,
+  { attempts = 10, initialDelayMs = 3000 } = {},
+): Promise<{ decryptionProof: `0x${string}`; plaintext: bigint }> {
+  let lastErr: unknown;
+  for (let i = 0; i < attempts; i++) {
+    try {
+      const res = await fetch(`${HANDLE_GATEWAY}/v0/public/${handle}`);
+      if (res.status === 404) {
+        throw new Error('Object not found');
+      }
+      if (!res.ok) {
+        throw new Error(`Gateway ${res.status}: ${await res.text()}`);
+      }
+      const json = (await res.json()) as
+        | { decryptionProof: string }
+        | { payload: { decryptionProof: string }; signature: string };
+      const decryptionProof =
+        ('decryptionProof' in json
+          ? json.decryptionProof
+          : json.payload.decryptionProof) as `0x${string}`;
+      // Proof layout: 65-byte sig + ABI-encoded value.
+      // For uint256 that's 32 bytes → read directly.
+      const hex = decryptionProof.replace(/^0x/, '');
+      const plaintextHex = hex.slice(65 * 2);
+      let plaintext = 0n;
+      for (let j = 0; j < plaintextHex.length; j += 2) {
+        plaintext = (plaintext << 8n) + BigInt(parseInt(plaintextHex.slice(j, j + 2), 16));
+      }
+      return { decryptionProof, plaintext };
+    } catch (err) {
+      lastErr = err;
+      const msg = (err as Error).message ?? '';
+      const isLag = msg.includes('Object not found') || msg.includes('404');
+      if (!isLag) throw err;
+      await new Promise((r) => setTimeout(r, initialDelayMs * (i + 1)));
+    }
+  }
+  throw lastErr;
+}
