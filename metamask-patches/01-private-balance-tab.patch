+): `0x${string}` {
+  // finalizeUnwrap(bytes32,bytes)  selector 0x65f94fdb
+  return (
+    '0x65f94fdb' +
+    stripHex(unwrapRequestId) +
+    padUint(0x40n) +
+    encodeDynamicBytes(decryptedAmountAndProof)
+  ) as `0x${string}`;
+}
