+const CONFIDENTIAL_TRANSFER_TOPIC =
+  '0x67500e8d0ed826d2194f514dd0d8124f35648ab6e3fb5e6ed867134cffe661e9';
+
+export type TransferEvent = {
+  token: `0x${string}`;
+  from: `0x${string}`;
+  to: `0x${string}`;
+  amountHandle: `0x${string}`;
+  txHash: `0x${string}`;
+  blockNumber: number;
+  direction: 'in' | 'out';
+};
+
+function addrTopic(addr: string): string {
+  return '0x' + addr.toLowerCase().replace(/^0x/, '').padStart(64, '0');
+}
+
+/**
+ * Fetch ConfidentialTransfer events involving `user` on the given token
+ * contracts in the last `lookbackBlocks` blocks. Merges "sent" and
+ * "received" into a single chronologically-sorted list.
+ */
+export async function fetchRecentTransfers(
+  user: string,
+  tokens: readonly string[],
+  // Arbitrum Sepolia produces a block every ~250ms, so 2M blocks ≈ 6 days.
+  { lookbackBlocks = 2_000_000, head = 30 }: { lookbackBlocks?: number; head?: number } = {},
+): Promise<TransferEvent[]> {
+  // Get latest block
+  const headRes = await fetch(ARB_SEPOLIA_RPC, {
+    method: 'POST',
+    headers: { 'content-type': 'application/json' },
+    body: JSON.stringify({ jsonrpc: '2.0', id: 1, method: 'eth_blockNumber', params: [] }),
+  });
+  const { result: latestHex } = (await headRes.json()) as { result: string };
+  const latest = parseInt(latestHex, 16);
+  const fromBlock = '0x' + Math.max(0, latest - lookbackBlocks).toString(16);
+  const toBlock = '0x' + latest.toString(16);
+  const userTopic = addrTopic(user);
+
+  async function getLogs(topics: (string | null | string[])[]): Promise<TransferEvent[]> {
+    const res = await fetch(ARB_SEPOLIA_RPC, {
+      method: 'POST',
+      headers: { 'content-type': 'application/json' },
+      body: JSON.stringify({
+        jsonrpc: '2.0', id: 1, method: 'eth_getLogs',
+        params: [{
+          address: tokens as string[],
+          topics, fromBlock, toBlock,
+        }],
+      }),
+    });
+    const json = (await res.json()) as {
+      result?: {
+        address: string; topics: string[]; data: string;
+        transactionHash: string; blockNumber: string;
+      }[];
+      error?: { message: string };
+    };
+    if (json.error) throw new Error(json.error.message);
+    return (json.result ?? []).map((l) => ({
+      token: l.address as `0x${string}`,
+      from: ('0x' + l.topics[1].slice(26)) as `0x${string}`,
+      to: ('0x' + l.topics[2].slice(26)) as `0x${string}`,
+      // Per ERC-7984: event ConfidentialTransfer(address indexed from,
+      // address indexed to, euint256 indexed amount) — amount is an indexed
+      // bytes32 (topics[3]), not in data.
+      amountHandle: (l.topics[3] ?? '0x' + '0'.repeat(64)) as `0x${string}`,
+      txHash: l.transactionHash as `0x${string}`,
+      blockNumber: parseInt(l.blockNumber, 16),
+      direction: 'in', // filled by caller
+    }));
+  }
+
+  const [outLogs, inLogs] = await Promise.all([
+    getLogs([CONFIDENTIAL_TRANSFER_TOPIC, userTopic, null]).then((ls) =>
+      ls.map((l) => ({ ...l, direction: 'out' as const })),
+    ),
+    getLogs([CONFIDENTIAL_TRANSFER_TOPIC, null, userTopic]).then((ls) =>
+      ls.map((l) => ({ ...l, direction: 'in' as const })),
+    ),
+  ]);
+
+  const all = [...outLogs, ...inLogs];
+  // Dedupe (same tx can appear twice if user sends to self)
+  const byKey = new Map<string, TransferEvent>();
+  for (const e of all) {
+    byKey.set(`${e.txHash}:${e.direction}`, e);
+  }
+  return Array.from(byKey.values())
+    .sort((a, b) => b.blockNumber - a.blockNumber)
+    .slice(0, head);
+}
