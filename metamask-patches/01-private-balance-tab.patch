+  }, []);
+
+  const closeAction = useCallback(() => {
+    setAction(null);
+    setFlow({ status: 'idle' });
+  }, []);
+
+  const dispatchTx = useCallback(
+    async (to: string, data: `0x${string}`, type: TransactionType) => {
+      const txMeta = await addTransaction(
+        {
+          from: ownerAddress as `0x${string}`,
+          to: to as `0x${string}`,
+          data,
+          value: '0x0',
+          chainId: chainIdHex,
+        } as Parameters<typeof addTransaction>[0],
+        { networkClientId, type },
+      );
+      return txMeta.hash as string;
+    },
+    [ownerAddress, chainIdHex, networkClientId],
+  );
+
+  const submitSend = useCallback(async () => {
+    if (!/^0x[0-9a-fA-F]{40}$/.test(recipient)) {
+      setFlow({ status: 'error', message: 'Invalid recipient address' });
+      return;
+    }
+    const raw = parseDecimalToRaw(amount, token.decimals);
+    if (raw === null || raw === 0n) {
+      setFlow({ status: 'error', message: 'Invalid amount' });
+      return;
+    }
+    try {
+      setFlow({ status: 'busy', label: 'Encrypting amount…' });
+      const { handle, proof } = await encryptUint256(token.address, ownerAddress, raw);
+      setFlow({ status: 'busy', label: 'Awaiting MetaMask confirmation…' });
+      const data = encodeConfidentialTransfer(recipient, handle, proof);
+      const hash = await dispatchTx(token.address, data, TransactionType.contractInteraction);
+      setFlow({ status: 'busy', label: 'Waiting for tx to mine…' });
+      await waitReceipt(hash);
+      setFlow({ status: 'done', message: `Sent. Tx ${hash.slice(0, 10)}…` });
+      onBalanceChanged();
+    } catch (err) {
+      setFlow({ status: 'error', message: (err as Error).message });
+    }
+  }, [recipient, amount, token.address, token.decimals, ownerAddress, dispatchTx, onBalanceChanged]);
+
+  const submitShield = useCallback(async () => {
+    const raw = parseDecimalToRaw(amount, token.decimals);
+    if (raw === null || raw === 0n) {
+      setFlow({ status: 'error', message: `Enter an ${token.underlyingSymbol} amount` });
+      return;
+    }
+    try {
+      // Step 1 — approve underlying
+      setFlow({ status: 'busy', label: '1/2 Approving ERC-20 — sign in MetaMask…' });
+      const approveData = encodeApprove(token.address, raw);
+      const approveHash = await dispatchTx(
+        token.underlying,
+        approveData,
+        TransactionType.tokenMethodApprove,
+      );
+      setFlow({ status: 'busy', label: '1/2 Waiting for approval to mine…' });
+      await waitReceipt(approveHash);
+      // Step 2 — wrap
+      setFlow({ status: 'busy', label: '2/2 Wrapping — sign in MetaMask…' });
+      const wrapData = encodeWrap(ownerAddress, raw);
+      const wrapHash = await dispatchTx(token.address, wrapData, TransactionType.contractInteraction);
+      setFlow({ status: 'busy', label: '2/2 Waiting for wrap to mine…' });
+      await waitReceipt(wrapHash);
+      setFlow({ status: 'done', message: `Shielded ${amount} ${token.underlyingSymbol}` });
+      onBalanceChanged();
+    } catch (err) {
+      setFlow({ status: 'error', message: (err as Error).message });
+    }
+  }, [amount, token, ownerAddress, dispatchTx, onBalanceChanged]);
+
+  const submitUnwrap = useCallback(async () => {
+    const raw = parseDecimalToRaw(amount, token.decimals);
+    if (raw === null || raw === 0n) {
+      setFlow({ status: 'error', message: 'Invalid amount' });
+      return;
+    }
+    try {
+      // Step 1 — encrypt amount, burn
+      setFlow({ status: 'busy', label: '1/2 Encrypting + burning — sign in MetaMask…' });
+      const { handle, proof } = await encryptUint256(token.address, ownerAddress, raw);
+      const burnData = encodeUnwrap(ownerAddress, ownerAddress, handle, proof);
+      const burnHash = await dispatchTx(token.address, burnData, TransactionType.contractInteraction);
+      setFlow({ status: 'busy', label: '1/2 Waiting for burn to mine…' });
+      const burnReceipt = await waitReceipt(burnHash);
+      const unwrapRequestId = parseUnwrapRequestIdFromLogs(burnReceipt.logs, token.address);
+      if (!unwrapRequestId) throw new Error('UnwrapRequested event not found in receipt');
+
+      // Step 2 — poll Gateway for public decryption proof, finalize
+      setFlow({ status: 'busy', label: '2/2 Fetching decryption proof (gateway lag ~3-10s)…' });
+      const { decryptionProof } = await publicDecryptProof(unwrapRequestId);
+      setFlow({ status: 'busy', label: '2/2 Finalizing — sign in MetaMask…' });
+      const finData = encodeFinalizeUnwrap(unwrapRequestId, decryptionProof);
+      const finHash = await dispatchTx(token.address, finData, TransactionType.contractInteraction);
+      setFlow({ status: 'busy', label: '2/2 Waiting for finalize to mine…' });
+      await waitReceipt(finHash);
+      setFlow({ status: 'done', message: `Unwrapped ${amount} → ${token.underlyingSymbol}` });
+      onBalanceChanged();
+    } catch (err) {
+      setFlow({ status: 'error', message: (err as Error).message });
+    }
+  }, [amount, token, ownerAddress, dispatchTx, onBalanceChanged]);
+
+  const submitViewer = useCallback(async () => {
+    if (!/^0x[0-9a-fA-F]{40}$/.test(viewerAddr)) {
+      setFlow({ status: 'error', message: 'Invalid viewer address' });
+      return;
+    }
+    if (load.status !== 'ok') {
+      setFlow({ status: 'error', message: 'Balance handle not loaded yet' });
+      return;
+    }
+    try {
+      setFlow({ status: 'busy', label: 'Granting viewer — sign in MetaMask…' });
+      const data = encodeAddViewer(load.handle, viewerAddr);
+      const hash = await dispatchTx(NOX_COMPUTE, data, TransactionType.contractInteraction);
+      setFlow({ status: 'busy', label: 'Waiting for tx to mine…' });
+      await waitReceipt(hash);
+      setFlow({ status: 'done', message: `Granted ${shortAddress(viewerAddr)}` });
+    } catch (err) {
+      setFlow({ status: 'error', message: (err as Error).message });
+    }
+  }, [viewerAddr, load, dispatchTx]);
+
+  let revealed: React.ReactNode;
+  if (load.status === 'loading') {
+    revealed = <Text as="span" variant={TextVariant.bodySm} color={TextColor.textAlternative}>Loading…</Text>;
+  } else if (load.status === 'error') {
+    revealed = <Text as="span" variant={TextVariant.bodySm} color={TextColor.errorDefault}>error</Text>;
+  } else if (load.status === 'ok' && load.zero) {
+    revealed = <Text as="span" variant={TextVariant.bodySmMedium} color={TextColor.textAlternative}>No balance on this account</Text>;
+  } else if (reveal.status === 'signing') {
+    revealed = <Text as="span" variant={TextVariant.bodySm} color={TextColor.textAlternative}>Awaiting signature…</Text>;
+  } else if (reveal.status === 'fetching') {
+    revealed = <Text as="span" variant={TextVariant.bodySm} color={TextColor.textAlternative}>Decrypting…</Text>;
+  } else if (reveal.status === 'error') {
+    revealed = <Text as="span" variant={TextVariant.bodySm} color={TextColor.errorDefault}>{reveal.message}</Text>;
+  } else if (reveal.status === 'ok') {
+    revealed = (
+      <Text as="span" variant={TextVariant.bodySmMedium} color={TextColor.successDefault}>
+        {formatAmount(reveal.value, token.decimals)} {token.symbol}
+      </Text>
+    );
+  } else if (load.status === 'ok') {
+    revealed = (
+      <Text as="span" variant={TextVariant.bodySmMedium} color={TextColor.textDefault}>
+        ******** {token.symbol}
+      </Text>
+    );
+  } else {
+    revealed = <Text as="span" variant={TextVariant.bodySmMedium}>—</Text>;
+  }
+
+  const handleChip = load.status === 'ok' && !load.zero && (
+    <Text
+      as="span"
+      variant={TextVariant.bodyXs}
+      color={TextColor.textMuted}
+      style={{ fontFamily: 'monospace' }}
+    >
+      handle {shortHandle(load.handle)}
+    </Text>
+  );
+
+  const canDecrypt = load.status === 'ok' && !load.zero;
+  const isRevealing = reveal.status === 'signing' || reveal.status === 'fetching';
+  const isRevealed = reveal.status === 'ok';
+
+  return (
+    <Box
+      padding={4}
+      borderColor={BorderColor.borderMuted}
+      borderRadius={BorderRadius.LG}
+      marginBottom={2}
+      display={Display.Flex}
+      flexDirection={FlexDirection.Column}
+      gap={2}
+    >
+      <Box display={Display.Flex} alignItems={AlignItems.center} gap={2}>
+        <TokenLogo symbol={token.symbol} underlyingSymbol={token.underlyingSymbol} />
+        <Box display={Display.Flex} flexDirection={FlexDirection.Column}>
+          <Text variant={TextVariant.bodyMdMedium}>
+            {token.symbol} · {token.network}
+          </Text>
+          {handleChip}
+        </Box>
+      </Box>
+
+      <Text variant={TextVariant.bodySm} color={TextColor.textAlternative}>
+        On-chain balance is encrypted.
+      </Text>
+
+      <Text variant={TextVariant.bodySm} color={TextColor.textAlternative}>
+        Revealed: {revealed}
+      </Text>
+
+      <Box display={Display.Flex} gap={2} flexWrap={undefined}>
+        <Button
+          variant={ButtonVariant.Secondary}
+          size={ButtonSize.Sm}
+          startIconName={IconName.Arrow2UpRight}
+          onClick={() => openAction('send')}
+          disabled={!canDecrypt || action !== null}
+        >
+          Send
+        </Button>
+        <Button
+          variant={ButtonVariant.Secondary}
+          size={ButtonSize.Sm}
+          startIconName={IconName.ShieldLock}
+          onClick={() => openAction('shield')}
+          disabled={action !== null}
+        >
+          Shield
+        </Button>
+        <Button
+          variant={ButtonVariant.Secondary}
+          size={ButtonSize.Sm}
+          startIconName={IconName.Export}
+          onClick={() => openAction('unwrap')}
+          disabled={!canDecrypt || action !== null}
+        >
+          Unwrap
+        </Button>
+        <Button
+          variant={ButtonVariant.Secondary}
+          size={ButtonSize.Sm}
+          startIconName={IconName.Eye}
+          onClick={() => openAction('viewers')}
+          disabled={!canDecrypt || action !== null}
+        >
+          Share
+        </Button>
+        <Button
+          variant={ButtonVariant.Link}
+          size={ButtonSize.Sm}
+          onClick={isRevealed ? onHide : onReveal}
+          disabled={!canDecrypt || isRevealing}
+        >
+          {isRevealed ? 'Hide' : isRevealing ? '…' : 'Decrypt'}
+        </Button>
+      </Box>
+
+      {action !== null && (
+        <ActionForm
+          action={action}
+          token={token}
+          flow={flow}
+          recipient={recipient}
+          setRecipient={setRecipient}
+          amount={amount}
+          setAmount={setAmount}
+          viewerAddr={viewerAddr}
+          setViewerAddr={setViewerAddr}
+          onConfirm={
+            action === 'send' ? submitSend
+            : action === 'shield' ? submitShield
+            : action === 'unwrap' ? submitUnwrap
+            : submitViewer
+          }
+          onClose={closeAction}
+        />
+      )}
+    </Box>
+  );
+}
+
+export default function PrivateBalanceTab() {
+  const ownerAddress = useSelector(getSelectedAddress) as string | undefined;
+  const networkClientId = useSelector(getSelectedNetworkClientId) as string;
+  const [loads, setLoads] = useState<Record<string, LoadState>>({});
+  const [reveals, setReveals] = useState<Record<string, RevealState>>({});
+  const [refetchTick, setRefetchTick] = useState(0);
+  const [activity, setActivity] = useState<TransferEvent[] | 'loading' | null>(null);
+
+  // TEMPORARILY DISABLED — bisecting activity crash
+  // useEffect(() => {
+  //   if (!ownerAddress) return;
+  //   let cancelled = false;
+  //   setActivity('loading');
+  //   (async () => {
+  //     try {
+  //       const events = await fetchRecentTransfers(
+  //         ownerAddress,
+  //         NOX_CTOKENS.map((t) => t.address),
+  //       );
+  //       if (!cancelled) setActivity(events);
+  //     } catch {
+  //       if (!cancelled) setActivity([]);
+  //     }
+  //   })();
+  //   return () => { cancelled = true; };
+  // }, [ownerAddress, refetchTick]);
+
+  useEffect(() => {
+    if (!ownerAddress) return;
+    let cancelled = false;
+    setLoads(() => {
+      const next: Record<string, LoadState> = {};
+      NOX_CTOKENS.forEach((t) => { next[t.address] = { status: 'loading' }; });
+      return next;
+    });
+    // Rehydrate reveal state from the module-level cache before the first
+    // fetch lands — lets us show plaintext immediately for handles we've
+    // already decrypted in this session.
+    setReveals({});
+    (async () => {
+      for (const token of NOX_CTOKENS) {
+        try {
+          const { handle, zero } = await fetchBalanceHandle(token.address, ownerAddress);
+          if (cancelled) return;
+          setLoads((prev) => ({ ...prev, [token.address]: { status: 'ok', handle, zero } }));
+          if (!zero) {
+            // Rehydrate plaintext from session storage if we decrypted this
+            // handle already (survives side-panel remount after signing).
+            const key = cacheKey(ownerAddress, handle);
+            const cached = await loadCachedValue(key);
+            console.log('[nox] rehydrate check', { key, hit: cached !== undefined });
+            if (cached !== undefined && !cancelled) {
+              setReveals((prev) => ({
+                ...prev,
+                [token.address]: { status: 'ok', value: cached },
+              }));
+            } else {
+              // Surface any persisted error from a previous failed decrypt
+              const storage = getSessionStorage();
+              if (storage) {
+                try {
+                  const out = await storage.get(`${key}:error`);
+                  const errMsg = out[`${key}:error`];
+                  if (typeof errMsg === 'string' && !cancelled) {
+                    setReveals((prev) => ({
+                      ...prev,
+                      [token.address]: { status: 'error', message: errMsg },
+                    }));
+                  }
+                } catch { /* noop */ }
+              }
+            }
+          }
+        } catch (err) {
+          if (!cancelled) {
+            setLoads((prev) => ({
+              ...prev,
+              [token.address]: { status: 'error', message: (err as Error).message },
+            }));
+          }
+        }
+      }
+    })();
+    return () => { cancelled = true; };
+  }, [ownerAddress, refetchTick]);
+
+  const revealToken = useCallback(
+    async (tokenAddress: string) => {
+      if (!ownerAddress) return;
+      const load = loads[tokenAddress];
+      if (!load || load.status !== 'ok' || load.zero) return;
+
+      const key = cacheKey(ownerAddress, load.handle);
+
+      // Fast-path: already decrypted this handle before in this session.
+      const cached = await loadCachedValue(key);
+      if (cached !== undefined) {
+        setReveals((prev) => ({ ...prev, [tokenAddress]: { status: 'ok', value: cached } }));
+        return;
+      }
+
+      setReveals((prev) => ({ ...prev, [tokenAddress]: { status: 'signing' } }));
+      try {
+        console.log('[nox] revealToken start', { tokenAddress, handle: load.handle });
+        // De-dupe concurrent reveals. Persist to session storage INSIDE the
+        // promise chain so the value is available even if our setReveals call
+        // happens on an unmounted side panel.
+        let pending = inflightDecrypts.get(key);
+        if (!pending) {
+          pending = noxDecrypt(ownerAddress, load.handle).then(async (v) => {
+            console.log('[nox] decrypt resolved, saving to session', { key, value: v.toString() });
+            await saveCachedValue(key, v);
+            return v;
+          }).finally(() => {
+            inflightDecrypts.delete(key);
+          });
+          inflightDecrypts.set(key, pending);
+        }
+        const value = await pending;
+        setReveals((prev) => ({ ...prev, [tokenAddress]: { status: 'ok', value } }));
+      } catch (err) {
+        console.error('[nox] revealToken failed', err);
+        // Also persist the error so if the side panel remounts, we can show
+        // the user what went wrong instead of silently reverting to ********.
+        const storage = getSessionStorage();
+        if (storage) {
+          try { await storage.set({ [`${key}:error`]: (err as Error).message }); } catch { /* noop */ }
+        }
+        setReveals((prev) => ({
+          ...prev,
+          [tokenAddress]: { status: 'error', message: (err as Error).message },
+        }));
+      }
+    },
+    [ownerAddress, loads],
+  );
+
+  const hideToken = useCallback(
+    (tokenAddress: string) => {
+      setReveals((prev) => ({ ...prev, [tokenAddress]: { status: 'hidden' } }));
+    },
+    [],
+  );
+
+  const decryptAll = useCallback(() => {
+    NOX_CTOKENS.forEach((t) => {
+      const load = loads[t.address];
+      if (load?.status === 'ok' && !load.zero) {
+        void revealToken(t.address);
+      }
+    });
+  }, [loads, revealToken]);
+
+  return (
+    <Box padding={4}>
+      <Box
+        display={Display.Flex}
+        justifyContent={JustifyContent.spaceBetween}
+        alignItems={AlignItems.center}
+        marginBottom={3}
+      >
+        <Box display={Display.Flex} alignItems={AlignItems.center} gap={2}>
+          <Text variant={TextVariant.bodyMdMedium}>Confidential tokens</Text>
+          {(() => {
+            const heldCount = NOX_CTOKENS.filter((t) => {
+              const l = loads[t.address];
+              return l?.status === 'ok' && !l.zero;
+            }).length;
+            return (
+              <Box
+                paddingLeft={2}
+                paddingRight={2}
+                borderRadius={BorderRadius.full}
+                backgroundColor={BackgroundColor.backgroundMuted}
+                style={{ minWidth: 22, textAlign: 'center', lineHeight: '20px', height: 20 }}
+              >
+                <Text
+                  as="span"
+                  variant={TextVariant.bodyXs}
+                  color={TextColor.textAlternative}
+                >
+                  {heldCount}
+                </Text>
+              </Box>
+            );
+          })()}
+        </Box>
+        <Button
+          variant={ButtonVariant.Primary}
+          size={ButtonSize.Sm}
+          startIconName={IconName.Eye}
+          onClick={decryptAll}
+        >
+          Decrypt all
+        </Button>
+      </Box>
+
+      {(() => {
+        const allLoaded = NOX_CTOKENS.every((t) => {
+          const s = loads[t.address]?.status;
+          return s === 'ok' || s === 'error';
+        });
+        const held = NOX_CTOKENS.filter((t) => {
+          const l = loads[t.address];
+          return l?.status === 'ok' && !l.zero;
+        });
+
+        if (!allLoaded) {
+          return (
+            <Text variant={TextVariant.bodySm} color={TextColor.textAlternative}>
+              Scanning known ERC-7984 tokens on Arbitrum Sepolia…
+            </Text>
+          );
+        }
+        if (held.length === 0) {
+          return (
+            <Box
+              padding={4}
+              borderColor={BorderColor.borderMuted}
+              borderRadius={BorderRadius.LG}
+              display={Display.Flex}
+              flexDirection={FlexDirection.Column}
+              alignItems={AlignItems.center}
+              gap={3}
+              style={{ textAlign: 'center' }}
+            >
+              <Box
+                display={Display.Flex}
+                alignItems={AlignItems.center}
+                justifyContent={JustifyContent.center}
+                borderRadius={BorderRadius.full}
+                backgroundColor={BackgroundColor.backgroundMuted}
+                style={{ width: 48, height: 48 }}
+              >
+                <Icon name={IconName.Lock} size={IconSize.Lg} color={TextColor.iconAlternative} />
+              </Box>
+              <Text variant={TextVariant.bodyMdMedium}>
+                No confidential balances yet
+              </Text>
+              <Text variant={TextVariant.bodySm} color={TextColor.textAlternative}>
+                Scanned {NOX_CTOKENS.length} known ERC-7984 wrappers on Arbitrum
+                Sepolia. Use Shield above to wrap an ERC-20 into its
+                confidential equivalent.
+              </Text>
+            </Box>
+          );
+        }
+        return held.map((token) => (
+          <CTokenCard
+            key={token.address}
+            token={token}
+            ownerAddress={ownerAddress ?? ''}
+            networkClientId={networkClientId}
+            load={loads[token.address] ?? { status: 'idle' }}
+            reveal={reveals[token.address] ?? { status: 'hidden' }}
+            onReveal={() => void revealToken(token.address)}
+            onHide={() => hideToken(token.address)}
+            onBalanceChanged={() => setRefetchTick((n) => n + 1)}
+          />
+        ));
+      })()}
+
+      <ActivitySection activity={activity} />
+
+      <Box marginTop={4}>
+        <Text variant={TextVariant.bodyXs} color={TextColor.textMuted}>
+          Auto-discovered by scanning {NOX_CTOKENS.length} known ERC-7984
+          wrappers on Arbitrum Sepolia. Balances are end-to-end encrypted in
+          a Trusted Execution Environment; decryption is gasless — MetaMask
+          signs an EIP-712 authorization that the Nox Handle Gateway
+          verifies before returning the ciphertext. Powered by Nox Protocol.
+        </Text>
+      </Box>
+    </Box>
+  );
+}
