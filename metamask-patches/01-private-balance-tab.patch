@@ -0,0 +1,61 @@
+const ARB_SEPOLIA_RPC = 'https://sepolia-rollup.arbitrum.io/rpc';
+const ZERO_HANDLE = '0x' + '00'.repeat(32);
+
+export const NOX_DAPP_ORIGIN =
+  (globalThis as { VITE_NOX_APP_ORIGIN?: string }).VITE_NOX_APP_ORIGIN ||
+  'http://localhost:5180';
+
+// Selector for confidentialBalanceOf(address) returning bytes32.
+// keccak256("confidentialBalanceOf(address)").slice(0, 4) = 0x344ff101
+const CONFIDENTIAL_BALANCE_OF_SELECTOR = '0x344ff101';
+
+function addrToCallData(address: string): string {
+  const clean = address.toLowerCase().replace(/^0x/, '').padStart(64, '0');
+  return CONFIDENTIAL_BALANCE_OF_SELECTOR + clean;
+}
+
+export async function fetchBalanceHandle(
+  token: string,
+  owner: string,
+): Promise<{ handle: string; zero: boolean }> {
+  const body = {
+    jsonrpc: '2.0',
+    id: 1,
+    method: 'eth_call',
+    params: [
+      { to: token, data: addrToCallData(owner) },
+      'latest',
+    ],
+  };
+
+  const res = await fetch(ARB_SEPOLIA_RPC, {
+    method: 'POST',
+    headers: { 'content-type': 'application/json' },
+    body: JSON.stringify(body),
+  });
+  if (!res.ok) throw new Error(`RPC ${res.status}: ${await res.text()}`);
+
+  const json = (await res.json()) as { result?: string; error?: { message: string } };
+  if (json.error) throw new Error(`RPC error: ${json.error.message}`);
+  if (!json.result || json.result.length !== 66) {
+    throw new Error(`Unexpected RPC result: ${JSON.stringify(json)}`);
+  }
+  return {
+    handle: json.result,
+    zero: json.result === ZERO_HANDLE,
+  };
+}
+
+type DeepLinkAction = 'decrypt' | 'send' | 'shield';
+
+export function buildDappDeepLink(
+  action: DeepLinkAction,
+  params: { token?: string; handle?: string } = {},
+): string {
+  const base = `${NOX_DAPP_ORIGIN}/`;
+  const q = new URLSearchParams();
+  q.set('view', action);
+  if (params.token) q.set('token', params.token);
+  if (params.handle) q.set('handle', params.handle);
+  return `${base}?${q.toString()}`;
+}
diff --git a/ui/components/app/assets/private-balance-tab/private-balance-tab.tsx b/ui/components/app/assets/private-balance-tab/private-balance-tab.tsx
