+}: {
+  token: (typeof NOX_CTOKENS)[number];
+  ownerAddress: string;
+  networkClientId: string;
+  load: LoadState;
+  reveal: RevealState;
+  onReveal: () => void;
+  onHide: () => void;
+  onBalanceChanged: () => void;
+}) {
+  const [action, setAction] = useState<Action | null>(null);
+  const [flow, setFlow] = useState<FlowStatus>({ status: 'idle' });
+  // Form inputs (shared, reset when opening/closing a form)
+  const [recipient, setRecipient] = useState('');
+  const [amount, setAmount] = useState('');
+  const [viewerAddr, setViewerAddr] = useState('');
