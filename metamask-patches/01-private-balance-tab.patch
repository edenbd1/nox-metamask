+function TokenLogo({ symbol }: { symbol: string }) {
+  const letter = symbol.replace(/^c/i, '').charAt(0).toUpperCase() || '?';
+  // Derive a stable hue from the symbol so each cToken has its own color
+  let hash = 0;
+  for (let i = 0; i < symbol.length; i++) hash = (hash * 31 + symbol.charCodeAt(i)) >>> 0;
+  const hue = hash % 360;
+  return (
+    <Box
+      display={Display.Flex}
+      alignItems={AlignItems.center}
+      justifyContent={JustifyContent.center}
+      borderRadius={BorderRadius.full}
+      style={{
+        width: 34, height: 34, position: 'relative',
+        background: `linear-gradient(135deg, hsl(${hue},75%,55%), hsl(${(hue + 40) % 360},70%,35%))`,
+        boxShadow: '0 2px 6px hsla(0,0%,0%,0.25)',
+      }}
+    >
+      <span style={{ color: 'white', fontSize: 14, fontWeight: 600, letterSpacing: '-0.02em' }}>
+        {letter}
+      </span>
+      <Box
+        display={Display.Flex}
+        alignItems={AlignItems.center}
+        justifyContent={JustifyContent.center}
+        backgroundColor={BackgroundColor.backgroundDefault}
+        borderRadius={BorderRadius.full}
+        style={{
+          position: 'absolute', bottom: -3, right: -3,
+          width: 16, height: 16,
+          border: '1.5px solid hsl(0,0%,10%)',
+        }}
+      >
+        <Icon name={IconName.Lock} size={IconSize.Xs} color={TextColor.iconDefault} />
+      </Box>
+    </Box>
+  );
+}
