+// Shared registry of known ERC-7984 confidential wrappers. Used by both the
+// cTokens tab (to scan balances) and the asset detail page (to decide whether
+// to show the Shield button on an ERC-20 like USDC or RLC).
+//
+// Today there's no public ERC-7984 registry, so this list is curated. Add
+// entries as new wrappers ship.
+
+export type NoxCToken = {
+  address: string;
+  symbol: string;
+  name: string;
+  network: string;
+  chainId: number;
+  underlying: string;
+  underlyingSymbol: string;
+  decimals: number;
+};
+
+export const NOX_CTOKENS: NoxCToken[] = [
+  {
+    // cdefi.iex.ec official Confidential USDC wrapper
+    address: '0x1CCeC6bC60dB15E4055D43Dc2531BB7D4E5B808e',
+    symbol: 'cUSDC',
+    name: 'Confidential USDC',
+    network: 'Arbitrum Sepolia',
+    chainId: 421614,
+    underlying: '0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d',
+    underlyingSymbol: 'USDC',
+    decimals: 6,
+  },
+  {
+    // Our own demo wrapper (also backed by Circle USDC) — shown if funded
+    address: '0x52a12dC4558063AB2a451f52DA721F24Cae72DeC',
+    symbol: 'cUSDC',
+    name: 'Confidential USDC (Nox demo)',
+    network: 'Arbitrum Sepolia',
+    chainId: 421614,
+    underlying: '0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d',
+    underlyingSymbol: 'USDC',
+    decimals: 6,
+  },
+];
+
+/**
+ * Find a confidential wrapper whose underlying ERC-20 matches the given
+ * address (case-insensitive). Returns the first match; some assets have
+ * multiple wrappers (e.g. official + demo) so this is a "is there at least
+ * one wrapper?" check rather than a strict 1-to-1 lookup.
+ */
+export function findWrapperByUnderlying(
+  underlyingAddress: string,
+  chainId?: number,
+): NoxCToken | undefined {
+  const want = underlyingAddress.toLowerCase();
+  return NOX_CTOKENS.find(
+    (t) =>
+      t.underlying.toLowerCase() === want &&
+      (chainId === undefined || t.chainId === chainId),
+  );
+}
+
+/**
+ * Same as findWrapperByUnderlying but returns true/false. Used by the asset
+ * page to decide whether to render the Shield button.
+ */
+export function hasConfidentialWrapper(
+  underlyingAddress: string,
+  chainId?: number,
+): boolean {
+  return findWrapperByUnderlying(underlyingAddress, chainId) !== undefined;
+}
+
+// Intent key written to chrome.storage.session when the user clicks Shield
+// from the public ERC-20 detail page. The cTokens tab consumes it on mount
+// to auto-open the Shield form on the matching CTokenCard.
+export const AUTO_OPEN_SHIELD_KEY = 'nox:autoOpenShield';
+export const AUTO_OPEN_SHIELD_TTL_MS = 30_000;
+
+export type AutoOpenShieldIntent = {
+  underlying: string;
+  chainId: number;
+  ts: number;
+};
+
+// Pending shield intent: the /shield page captures user input then writes
+// this and navigates to home/cTokens. The cTokens tab actually runs the
+// 2-step approve+wrap because IT lives on the home route and survives
+// MetaMask's post-confirmation redirect — whereas /shield gets unmounted
+// the moment the first popup is confirmed.
+export const PENDING_SHIELD_KEY = 'nox:pendingShield';
+export const PENDING_SHIELD_TTL_MS = 60_000;
+
+export type PendingShieldIntent = {
+  underlying: string;
+  wrapper: string;
+  chainId: number;
+  amountRaw: string; // bigint serialized; chrome.storage doesn't take bigint
+  ts: number;
+};
