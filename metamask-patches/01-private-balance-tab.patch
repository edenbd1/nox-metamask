+// Full-screen Shield page: lets the user wrap a public ERC-20 (e.g. USDC)
+// into its confidential ERC-7984 wrapper (e.g. cUSDC). Reached from the
+// Shield IconButton on the asset detail page.
+//
+// Structure mirrors the Send page (sticky header, centered token icon,
+// amount input with Max, Continue button at the bottom).
+
+import React, { useCallback, useEffect, useMemo, useState } from 'react';
+import { useSelector } from 'react-redux';
+import { useNavigate, useSearchParams } from 'react-router-dom';
+import {
+  AlignItems,
+  BackgroundColor,
+  BlockSize,
+  BorderColor,
+  BorderRadius,
+  Display,
+  FlexDirection,
+  IconColor,
+  JustifyContent,
+  TextColor,
+  TextVariant,
+} from '../../helpers/constants/design-system';
+import {
+  Box,
+  Button,
+  ButtonSize,
+  ButtonVariant,
+  Icon,
+  IconName,
+  IconSize,
+  Text,
+} from '../../components/component-library';
+import { getSelectedAddress } from '../../selectors';
+import {
+  findWrapperByUnderlying,
+  PENDING_SHIELD_KEY,
+  type PendingShieldIntent,
+} from '../../components/app/assets/private-balance-tab/nox-tokens';
+import { setDefaultHomeActiveTabName } from '../../store/actions';
+import { AccountOverviewTabKey } from '../../../shared/constants/app-state';
+
+const ARB_SEPOLIA_RPC = 'https://sepolia-rollup.arbitrum.io/rpc';
+
+async function rpcCall<T = unknown>(method: string, params: unknown[]): Promise<T> {
+  const res = await fetch(ARB_SEPOLIA_RPC, {
+    method: 'POST',
+    headers: { 'content-type': 'application/json' },
+    body: JSON.stringify({ jsonrpc: '2.0', id: 1, method, params }),
+  });
+  const json = (await res.json()) as { result?: T; error?: { message: string } };
+  if (json.error) throw new Error(json.error.message);
+  return json.result as T;
+}
+
+const BALANCE_OF_SELECTOR = '0x70a08231';
+function encodeBalanceOf(owner: string): string {
+  return BALANCE_OF_SELECTOR + owner.replace(/^0x/, '').padStart(64, '0');
+}
+
+async function fetchErc20Balance(token: string, owner: string): Promise<bigint> {
+  const data = encodeBalanceOf(owner);
+  const hex = await rpcCall<string>('eth_call', [{ to: token, data }, 'latest']);
+  if (!hex || hex === '0x') return 0n;
+  return BigInt(hex);
+}
+
+function formatAmount(v: bigint, decimals: number): string {
+  if (v === 0n) return '0';
+  const unit = 10n ** BigInt(decimals);
+  const whole = v / unit;
+  const frac = v % unit;
+  if (frac === 0n) return whole.toString();
+  const fracStr = frac.toString().padStart(decimals, '0').replace(/0+$/, '');
+  return `${whole}.${fracStr}`;
+}
+
+function parseDecimalToRaw(input: string, decimals: number): bigint | null {
+  if (!/^\d+(\.\d+)?$/.test(input.trim())) return null;
+  const [whole, frac = ''] = input.trim().split('.');
+  if (frac.length > decimals) return null;
+  const padded = (frac + '0'.repeat(decimals)).slice(0, decimals);
+  return BigInt(whole) * 10n ** BigInt(decimals) + BigInt(padded || '0');
+}
+
+type FlowState =
+  | { status: 'idle' }
+  | { status: 'busy'; label: string }
+  | { status: 'done'; message: string }
+  | { status: 'error'; message: string };
+
+export default function ShieldPage() {
+  const navigate = useNavigate();
+  const [searchParams] = useSearchParams();
+  const ownerAddress = useSelector(getSelectedAddress) as string | undefined;
+
+  const assetParam = searchParams.get('asset')?.toLowerCase() ?? '';
+  const chainIdParam = searchParams.get('chainId') ?? '';
+
+  const wrapper = useMemo(() => {
+    if (!assetParam || !chainIdParam) return undefined;
+    const chainIdNum = parseInt(chainIdParam.replace(/^0x/, ''), 16);
+    return findWrapperByUnderlying(assetParam, chainIdNum);
+  }, [assetParam, chainIdParam]);
+
+  const [amount, setAmount] = useState('');
+  const [flow, setFlow] = useState<FlowState>({ status: 'idle' });
+  const [balance, setBalance] = useState<bigint | null>(null);
+
+  // Fetch underlying balance for "X available" + Max button.
+  useEffect(() => {
+    if (!wrapper || !ownerAddress) return;
+    let cancelled = false;
+    fetchErc20Balance(wrapper.underlying, ownerAddress)
+      .then((v) => { if (!cancelled) setBalance(v); })
+      .catch(() => { if (!cancelled) setBalance(0n); });
+    return () => { cancelled = true; };
+  }, [wrapper, ownerAddress]);
+
+  const onMax = useCallback(() => {
+    if (!wrapper || balance === null) return;
+    setAmount(formatAmount(balance, wrapper.decimals));
+  }, [balance, wrapper]);
+
+  const onContinue = useCallback(async () => {
+    if (!wrapper || !ownerAddress) return;
+    const raw = parseDecimalToRaw(amount, wrapper.decimals);
+    if (raw === null || raw === 0n) {
+      setFlow({ status: 'error', message: 'Invalid amount' });
+      return;
+    }
+    if (balance !== null && raw > balance) {
+      setFlow({ status: 'error', message: 'Amount exceeds your balance' });
+      return;
+    }
+
+    // ARCHITECTURE NOTE — why we don't fire txs from here:
+    //
+    // MetaMask's TransactionController, after the user confirms a popup
+    // initiated by addTransaction(...) with origin: ORIGIN_METAMASK,
+    // navigates the wallet UI back to '/'. That unmounts /shield, killing
+    // any in-flight await for the second tx. Two failure modes we hit:
+    //   (1) Sequential awaits: step 2 (wrap) never runs after step 1
+    //       (approve) because the page is gone before the next await
+    //       resumes.
+    //   (2) Parallel addTransactionAndWaitForPublish: both txs share the
+    //       same gas estimation snapshot taken at submit time. Arbitrum
+    //       Sepolia's base fee jiggles by ~10-30k wei during the user's
+    //       signing window, and MetaMask's tight maxFeePerGas (only ~2k
+    //       wei above baseFee) gets rejected by the public RPC with
+    //       "max fee per gas less than block base fee".
+    //
+    // Fix: this page is now UI-only. We persist a PendingShieldIntent and
+    // navigate to home → cTokens tab. The cTokens tab is rendered inside
+    // the home route, which is exactly where MetaMask redirects after a
+    // popup confirmation, so it doesn't unmount during the 2-step flow.
+    // It picks up the intent on mount and runs the proven sequential
+    // approve→await→wrap→await flow that already works for the inline
+    // shield form on cTokens cards.
+
+    const intent: PendingShieldIntent = {
+      underlying: wrapper.underlying,
+      wrapper: wrapper.address,
+      chainId: wrapper.chainId,
+      amountRaw: raw.toString(),
+      ts: Date.now(),
+    };
+
+    try {
+      const chromeRef = (
+        globalThis as { chrome?: { storage?: { session?: { set: (i: Record<string, unknown>) => Promise<void> } } } }
+      ).chrome;
+      const session = chromeRef?.storage?.session;
+      if (session) {
+        await session.set({ [PENDING_SHIELD_KEY]: intent });
+        console.log('[nox] /shield wrote pendingShield intent', intent);
+      } else {
+        console.warn('[nox] /shield: chrome.storage.session not available');
+      }
+    } catch (err) {
+      console.error('[nox] /shield: failed to write intent', err);
+    }
+
+    // Pre-select the cTokens tab so the user lands there. The Redux-backed
+    // setDefaultHomeActiveTabName is async and may not be visible to the
+    // home renderer in time, so we ALSO push ?tab=private-balance into the
+    // URL — useTabState reads the URL first.
+    void setDefaultHomeActiveTabName(AccountOverviewTabKey.PrivateBalance);
+    navigate(`/?tab=${AccountOverviewTabKey.PrivateBalance}`);
+  }, [amount, balance, wrapper, ownerAddress, navigate]);
+
+  if (!wrapper) {
+    return (
+      <Box padding={4}>
+        <Text variant={TextVariant.bodyMd} color={TextColor.errorDefault}>
+          No confidential wrapper is registered for this token.
+        </Text>
+      </Box>
+    );
+  }
+
+  const busy = flow.status === 'busy';
+  const done = flow.status === 'done';
+  const letter =
+    wrapper.underlyingSymbol.charAt(0).toUpperCase() || '?';
+
+  return (
+    <Box
+      backgroundColor={BackgroundColor.backgroundDefault}
+      display={Display.Flex}
+      flexDirection={FlexDirection.Column}
+      height={BlockSize.Full}
+      width={BlockSize.Full}
+      style={{ minHeight: '100vh' }}
+    >
+      {/* Header */}
+      <Box
+        display={Display.Flex}
+        alignItems={AlignItems.center}
+        justifyContent={JustifyContent.spaceBetween}
+        padding={4}
+      >
+        <button
+          type="button"
+          onClick={() => navigate(-1)}
+          aria-label="Back"
+          style={{
+            background: 'transparent',
+            border: 'none',
+            padding: 4,
+            cursor: 'pointer',
+            color: 'var(--color-icon-default)',
+            display: 'flex',
+            alignItems: 'center',
+          }}
